---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageBanner from "../../components/PageBanner.astro";
---

<Layout
  title="Mobile Sandblasting in Farmington Hills, MI | Blasting Jack"
  description="Mobile sandblasting in Farmington Hills, MI. Surface preparation for corporate campuses, parking structures, light manufacturing, and commercial building steel along I-696. Blasting Jack, Warren MI."
  canonical="https://blastingjack.com/areas-served/farmington-hills-mobile-sandblasting/"
>
  <Header />
  <PageBanner
    label="Areas Served"
    title="Mobile Sandblasting in Farmington Hills, MI"
    subtitle="Surface preparation for Farmington Hills' corporate campuses, parking structures, and light manufacturing operations along the I-696 corridor."
  />

  <!-- Intro -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] tracking-[-0.03em] mb-6">
            Corporate and commercial blasting in Farmington Hills
          </h2>
          <p class="text-body text-[17px] leading-relaxed mb-4">
            Farmington Hills is one of Oakland County's most significant corporate and commercial cities — roughly 82,000 residents and a dense concentration of automotive and technology corporate headquarters, engineering campuses, and office facilities along I-696. The commercial and corporate real estate base in Farmington Hills creates consistent demand for building maintenance, parking structure upkeep, and facility renovation work that includes surface preparation.
          </p>
          <p class="text-body text-[17px] leading-relaxed mb-4">
            From our Warren base, Farmington Hills is roughly 25 to 30 miles via I-696 — within our standard Oakland County service range. We serve corporate campus building steel, parking structure maintenance, light manufacturing, and commercial building surface prep in Farmington Hills without unusual mobilization costs. The I-696 corridor puts us and Farmington Hills on the same east-west trunk road, which helps.
          </p>
          <p class="text-body text-[17px] leading-relaxed">
            Vapor and dustless blasting is frequently the right choice for Farmington Hills corporate campus work — occupied facilities near engineering or office areas don't mix well with conventional sandblasting dust. Our MistBlaster system handles this where dust control matters.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-light-bg p-6 rounded-lg">
            <h3 class="font-heading text-[18px] font-semibold text-heading mb-3">Services available in Farmington Hills</h3>
            <ul class="space-y-2 text-body text-[15px]">
              {[
                ["Mobile Sandblasting", "/services/mobile-sandblasting/"],
                ["Abrasive Blasting", "/services/abrasive-blasting/"],
                ["Vapor / Dustless Blasting", "/services/vapor-dustless-blasting/"],
                ["Rust Removal", "/services/rust-removal/"],
                ["Coating Removal", "/services/coating-removal/"],
                ["Steel Surface Preparation", "/services/steel-surface-preparation/"],
                ["Equipment Blasting", "/services/equipment-blasting/"],
                ["Structural Steel Blasting", "/services/structural-steel-blasting/"],
              ].map(([label, href]) => (
                <li>
                  <a href={href} class="flex items-center gap-2 hover:text-primary transition-colors">
                    <span class="text-primary">→</span>{label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Project types -->
  <section class="py-16 md:py-20 bg-light-bg">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] tracking-[-0.03em] mb-10">
        Project types in Farmington Hills
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: "Corporate Campus Building Steel", desc: "Corporate campuses and headquarters facilities in Farmington Hills have structural steel, curtain walls, and architectural metal that require surface preparation during renovation and planned maintenance programs." },
          { title: "Parking Structures", desc: "Corporate and commercial parking structures throughout Farmington Hills require surface preparation on structural steel elements — blasting to remove corrosion and prepare for protective coating as part of a maintenance program." },
          { title: "Light Manufacturing", desc: "Light manufacturing and industrial tenants in Farmington Hills' business parks have production equipment and structural steel requiring blasting during planned maintenance windows." },
          { title: "Equipment and Fleet", desc: "Industrial operators and contractors based in Farmington Hills use mobile blasting to restore equipment and fleet vehicles on-site at their yards and facilities." },
          { title: "Commercial Building Steel", desc: "Commercial buildings along Farmington Road, Orchard Lake Road, and the I-696 corridor have structural and architectural steel requiring surface preparation during renovation and maintenance cycles." },
          { title: "Industrial Facilities", desc: "Industrial operations in Farmington Hills have process equipment, storage vessels, and facility steel requiring periodic surface preparation during maintenance shutdowns." },
        ].map(item => (
          <div class="bg-white border border-gray-200 p-6 rounded-lg">
            <h3 class="font-heading text-[17px] font-semibold text-heading mb-2">{item.title}</h3>
            <p class="text-body text-[15px] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby areas -->
  <section class="py-12 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <h3 class="font-heading text-[20px] font-semibold text-heading mb-4">Nearby service areas</h3>
      <div class="flex flex-wrap gap-3">
        {[
          ["Oakland County", "/areas-served/oakland-county-mobile-sandblasting/"],
          ["Novi", "/areas-served/novi-mobile-sandblasting/"],
          ["Southfield", "/areas-served/southfield-mobile-sandblasting/"],
          ["Livonia", "/areas-served/livonia-mobile-sandblasting/"],
        ].map(([label, href]) => (
          <a href={href} class="inline-block bg-white border border-gray-200 text-body text-[14px] font-medium px-4 py-2 rounded hover:border-primary hover:text-primary transition-colors">{label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24 bg-light-bg">
    <div class="max-w-[900px] mx-auto px-6">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {[
          { q: "Does Blasting Jack serve Farmington Hills?", a: "Yes — Farmington Hills is within our standard Oakland County service range from our Warren base, roughly 25 to 30 miles via I-696. We serve corporate campus facilities, parking structures, light manufacturing, and commercial building steel in Farmington Hills." },
          { q: "Can you do dustless blasting at a corporate campus in Farmington Hills?", a: "Yes. Corporate campus facilities with occupied adjacent spaces are good candidates for vapor/dustless blasting — it dramatically reduces airborne debris compared to conventional sandblasting. We assess the site and recommend the appropriate method." },
          { q: "Do you handle parking structure maintenance in Farmington Hills?", a: "Yes. Parking structure blasting involves surface preparation on structural steel columns, beams, and connections as part of a protective coating maintenance program. We work nights and weekends to minimize disruption to parking operations." },
          { q: "What corporate facility work do you handle in Farmington Hills?", a: "Structural steel surface prep, coating removal, equipment blasting, and facility renovation surface preparation are common at Farmington Hills corporate campuses. We coordinate with facility managers to schedule around operations." },
          { q: "How do I get a quote for Farmington Hills work?", a: "Contact us through our website or call directly. Describe the facility, asset type, and scope. We'll follow up to confirm availability and provide a project-specific quote." },
        ].map(item => (
          <div class="bg-white border border-gray-200 p-6 rounded-lg">
            <h3 class="font-heading text-[17px] font-semibold text-heading mb-2">{item.q}</h3>
            <p class="text-body text-[16px]">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-dark">
    <div class="max-w-[1400px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <h2 class="font-heading text-[28px] md:text-[40px] font-medium leading-[1.2] tracking-[-0.045em] text-white">
        Need blasting in Farmington Hills?
      </h2>
      <a href="/#contact" class="inline-block bg-primary text-white font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-primary hover:bg-primary-hover transition-all duration-300 shrink-0">
        Request a Free Estimate
      </a>
    </div>
  </section>

  <Footer />
</Layout>
