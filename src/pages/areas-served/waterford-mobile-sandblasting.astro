---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageBanner from "../../components/PageBanner.astro";
---

<Layout
  title="Mobile Sandblasting in Waterford, MI | Blasting Jack"
  description="Mobile sandblasting in Waterford, MI. Surface preparation for manufacturing facilities, fleet yards, commercial building steel, and construction equipment along M-59. Blasting Jack, Warren MI."
  canonical="https://blastingjack.com/areas-served/waterford-mobile-sandblasting/"
>
  <Header />
  <PageBanner
    label="Areas Served"
    title="Mobile Sandblasting in Waterford, MI"
    subtitle="Surface preparation for Waterford's manufacturing operations, fleet yards, and commercial facilities along the M-59 corridor."
  />

  <!-- Intro -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] tracking-[-0.03em] mb-6">
            Manufacturing and commercial blasting along M-59 in Waterford
          </h2>
          <p class="text-body text-[17px] leading-relaxed mb-4">
            Waterford Township is a large Oakland County township of roughly 72,000 with significant commercial and industrial development along the M-59 corridor. Manufacturing operations, fleet yards, construction equipment companies, and commercial businesses generate steady demand for on-site surface preparation work. Waterford sits in the middle of Oakland County's industrial corridor — between Auburn Hills and Pontiac — and has its own industrial base separate from those larger cities.
          </p>
          <p class="text-body text-[17px] leading-relaxed mb-4">
            From our Warren base, Waterford is roughly 35 to 40 miles via I-75 or M-59 — within our standard Oakland County service range. We serve manufacturing maintenance, fleet and equipment blasting, commercial building steel, and construction equipment yards in Waterford without unusual mobilization costs.
          </p>
          <p class="text-body text-[17px] leading-relaxed">
            Construction equipment and contractor fleet blasting is a common request in Waterford. The M-59 corridor has a concentration of construction companies and heavy equipment operators whose trucks, trailers, and equipment need rust stripped and coatings refreshed — done on-site at their yards, not hauled to a shop.
          </p>
        </div>
        <div class="space-y-4">
          <div class="bg-light-bg p-6 rounded-lg">
            <h3 class="font-heading text-[18px] font-semibold text-heading mb-3">Services available in Waterford</h3>
            <ul class="space-y-2 text-body text-[15px]">
              {[
                ["Mobile Sandblasting", "/services/mobile-sandblasting/"],
                ["Abrasive Blasting", "/services/abrasive-blasting/"],
                ["Vapor / Dustless Blasting", "/services/vapor-dustless-blasting/"],
                ["Industrial Sandblasting", "/services/industrial-sandblasting/"],
                ["Rust Removal", "/services/rust-removal/"],
                ["Coating Removal", "/services/coating-removal/"],
                ["Equipment Blasting", "/services/equipment-blasting/"],
                ["Steel Surface Preparation", "/services/steel-surface-preparation/"],
              ].map(([label, href]) => (
                <li>
                  <a href={href} class="flex items-center gap-2 hover:text-primary transition-colors">
                    <span class="text-primary">→</span>{label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Project types -->
  <section class="py-16 md:py-20 bg-light-bg">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] tracking-[-0.03em] mb-10">
        Project types in Waterford
      </h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          { title: "Manufacturing and Industrial Facilities", desc: "Manufacturing operations throughout Waterford have structural steel, production equipment, and process assets requiring periodic surface preparation during planned maintenance windows." },
          { title: "Fleet and Equipment Yards", desc: "Waterford's construction companies, equipment rental operations, and fleet operators use mobile blasting to restore trucks, trailers, excavators, and work equipment on-site at their yards." },
          { title: "Commercial Building Steel", desc: "Commercial buildings along M-59 and Waterford's commercial corridors have structural and architectural steel requiring surface preparation during renovation and maintenance cycles." },
          { title: "Construction Equipment", desc: "Heavy equipment operators based in Waterford need rust and old coatings removed from excavators, skid steers, dump trucks, and other construction equipment. Mobile blasting handles this on-site." },
          { title: "Parking Structures", desc: "Commercial and municipal parking structures in Waterford require surface preparation on structural steel elements as part of protective coating maintenance programs." },
          { title: "Municipal Infrastructure", desc: "Township and county infrastructure assets — bridges, utility structures, and public facility steel — require SSPC-standard surface preparation before protective coating application." },
        ].map(item => (
          <div class="bg-white border border-gray-200 p-6 rounded-lg">
            <h3 class="font-heading text-[17px] font-semibold text-heading mb-2">{item.title}</h3>
            <p class="text-body text-[15px] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby areas -->
  <section class="py-12 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <h3 class="font-heading text-[20px] font-semibold text-heading mb-4">Nearby service areas</h3>
      <div class="flex flex-wrap gap-3">
        {[
          ["Oakland County", "/areas-served/oakland-county-mobile-sandblasting/"],
          ["Pontiac", "/areas-served/pontiac-mobile-sandblasting/"],
          ["Auburn Hills", "/areas-served/auburn-hills-industrial-sandblasting/"],
        ].map(([label, href]) => (
          <a href={href} class="inline-block bg-white border border-gray-200 text-body text-[14px] font-medium px-4 py-2 rounded hover:border-primary hover:text-primary transition-colors">{label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24 bg-light-bg">
    <div class="max-w-[900px] mx-auto px-6">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-heading leading-[1.2] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {[
          { q: "Does Blasting Jack serve Waterford?", a: "Yes — Waterford is within our standard Oakland County service range from our Warren base, roughly 35 to 40 miles via I-75 or M-59. Manufacturing operations, fleet and equipment yards, construction equipment, and commercial building steel in Waterford are all within our regular service scope." },
          { q: "Can you blast construction equipment on-site in Waterford?", a: "Yes. Construction equipment — excavators, trailers, dump trucks, and skid steers — is blasted on-site at your yard or job site. We bring the equipment to you so you don't have to move large pieces to a shop." },
          { q: "What manufacturing blasting do you handle in Waterford?", a: "Structural steel, production equipment, tanks, and industrial assets are the common scope. We schedule around production windows and can work nights, weekends, and during planned shutdowns." },
          { q: "Do you work on commercial buildings along M-59 in Waterford?", a: "Yes. Commercial building steel along M-59 and Waterford's other commercial corridors — renovation, facade work, and building maintenance — is within our scope." },
          { q: "Can you handle fleet and trailer blasting for Waterford equipment rental companies?", a: "Yes. Equipment rental fleets and fleet operators in Waterford use mobile blasting to refresh trailers, trucks, and rental equipment. We blast on-site at your yard — no hauling required." },
        ].map(item => (
          <div class="bg-white border border-gray-200 p-6 rounded-lg">
            <h3 class="font-heading text-[17px] font-semibold text-heading mb-2">{item.q}</h3>
            <p class="text-body text-[16px]">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 md:py-16 bg-dark">
    <div class="max-w-[1400px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <h2 class="font-heading text-[28px] md:text-[40px] font-medium leading-[1.2] tracking-[-0.045em] text-white">
        Need blasting in Waterford?
      </h2>
      <a href="/#contact" class="inline-block bg-primary text-white font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-primary hover:bg-primary-hover transition-all duration-300 shrink-0">
        Request a Free Estimate
      </a>
    </div>
  </section>

  <Footer />
</Layout>
