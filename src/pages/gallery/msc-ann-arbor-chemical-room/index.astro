---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PageBanner from "../../../components/PageBanner.astro";

const videos = [
  { src: "/videos/msc-chem-1.mp4", label: "Chemical room blast and repaint — clip 1" },
  { src: "/videos/msc-chem-2.mp4", label: "Chemical room blast and repaint — clip 2" },
  { src: "/videos/msc-chem-3.mp4", label: "Chemical room blast and repaint — clip 3" },
  { src: "/videos/msc-chem-4.mp4", label: "Chemical room blast and repaint — clip 4" },
  { src: "/videos/msc-chem-5.mp4", label: "Chemical room blast and repaint — clip 5" },
  { src: "/videos/msc-chem-6.mp4", label: "Chemical room blast and repaint — clip 6" },
];
---

<Layout
  title="Chemical Room Blast and Repaint | Blasting Jack"
  description="Full blast and repaint of a chemical room — surface preparation and protective coating by Blasting Jack."
  canonical="https://blastingjack.com/gallery/msc-ann-arbor-chemical-room/"
>
  <Header />
  <PageBanner
    label="Project Gallery"
    title="Chemical Room Blast and Repaint"
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">

      <div class="flex items-center gap-3 mb-10">
        <a href="/gallery/" class="text-body text-[14px] hover:text-primary transition-colors flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          All Projects
        </a>
        <span class="text-gray-300">/</span>
        <span class="text-[14px] text-heading font-medium">Chemical Room Blast and Repaint</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {videos.map((vid) => (
          <div class="rounded-lg overflow-hidden bg-black shadow-md">
            <video
              controls
              playsinline
              preload="metadata"
              class="w-full max-h-[400px] object-contain"
              aria-label={vid.label}
            >
              <source src={vid.src} type="video/mp4" />
            </video>
          </div>
        ))}
      </div>

      <p class="text-body text-[14px] mt-5 text-center">{videos.length} videos</p>
    </div>
  </section>

  <section class="py-12 md:py-16" style="background-color: #1a1a1a;">
    <div class="max-w-[1400px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <h2 class="font-heading text-[28px] md:text-[44px] font-medium leading-[1.2] tracking-[-0.045em] text-white">
        Have a similar project?
      </h2>
      <a
        href="/#contact"
        class="inline-block bg-white text-black font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-white hover:bg-transparent hover:text-white transition-all duration-300 shrink-0"
      >
        Get a Free Estimate
      </a>
    </div>
  </section>

  <Footer />
</Layout>
