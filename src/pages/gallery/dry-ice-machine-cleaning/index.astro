---
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import PageBanner from "../../../components/PageBanner.astro";
import { Image } from "astro:assets";

import g45 from "../../../assets/images/gallery-work-45.jpg";

const images = [
  { src: g45, alt: "Dry-ice blasting for industrial machine cleaning — Luxwall" },
];
---

<Layout
  title="Dry-Ice Blasting for Machine Cleaning | Blasting Jack"
  description="Dry-ice blasting for industrial machine cleaning — non-abrasive surface cleaning by Blasting Jack."
  canonical="https://blastingjack.com/gallery/dry-ice-machine-cleaning/"
>
  <Header />
  <PageBanner
    label="Project Gallery"
    title="Dry-Ice Blasting for Machine Cleaning"
  />

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">

      <div class="flex items-center gap-3 mb-10">
        <a href="/gallery/" class="text-body text-[14px] hover:text-primary transition-colors flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          All Projects
        </a>
        <span class="text-gray-300">/</span>
        <span class="text-[14px] text-heading font-medium">Dry-Ice Machine Cleaning</span>
      </div>

      <!-- Videos -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        {[
          { src: "/videos/luxwall-1.mp4", label: "Dry-ice blasting in action" },
          { src: "/videos/luxwall-2.mp4", label: "Machine cleaning — continued" },
        ].map((vid) => (
          <div class="rounded-lg overflow-hidden bg-black shadow-md">
            <video
              controls
              playsinline
              preload="metadata"
              class="w-full max-h-[400px] object-contain"
              aria-label={vid.label}
            >
              <source src={vid.src} type="video/mp4" />
            </video>
          </div>
        ))}
      </div>

      <!-- Photos -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
        {images.map((img, i) => (
          <div
            class="group relative aspect-[4/3] overflow-hidden rounded-lg cursor-pointer bg-gray-100"
            data-lightbox-trigger
            data-lightbox-index={i}
          >
            <Image
              src={img.src}
              alt={img.alt}
              width={640}
              height={480}
              class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
              <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 scale-75 group-hover:scale-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-body text-[14px] mt-5 text-center">2 videos &middot; {images.length} photo</p>
    </div>
  </section>

  <section class="py-12 md:py-16" style="background-color: #1a1a1a;">
    <div class="max-w-[1400px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <h2 class="font-heading text-[28px] md:text-[44px] font-medium leading-[1.2] tracking-[-0.045em] text-white">
        Have a similar project?
      </h2>
      <a
        href="/#contact"
        class="inline-block bg-white text-black font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-white hover:bg-transparent hover:text-white transition-all duration-300 shrink-0"
      >
        Get a Free Estimate
      </a>
    </div>
  </section>

  <Footer />

  <div
    id="gallery-lightbox"
    class="fixed inset-0 z-[300] bg-black/92 backdrop-blur-sm items-center justify-center"
    style="display:none"
    role="dialog"
    aria-modal="true"
  >
    <button id="lb-close" class="absolute top-5 right-5 text-white/70 hover:text-white transition-colors z-10 p-2" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="w-full h-full flex items-center justify-center px-16">
      <img id="lb-img" src="" alt="" class="max-w-full max-h-[90vh] object-contain rounded-lg shadow-2xl" />
    </div>
  </div>
</Layout>

<script>
  function init() {
    const lb = document.getElementById("gallery-lightbox") as HTMLElement;
    const lbImg = document.getElementById("lb-img") as HTMLImageElement;
    const triggers = Array.from(document.querySelectorAll("[data-lightbox-trigger]"));
    const srcs: string[] = [];
    const alts: string[] = [];

    triggers.forEach((t) => {
      const img = t.querySelector("img");
      if (img) { srcs.push(img.src); alts.push(img.alt); }
    });

    function open(i: number) {
      lbImg.src = srcs[i];
      lbImg.alt = alts[i];
      lb.style.display = "flex";
      document.body.style.overflow = "hidden";
    }
    function close() {
      lb.style.display = "none";
      document.body.style.overflow = "";
    }

    triggers.forEach((t) => {
      t.addEventListener("click", () => open(parseInt(t.getAttribute("data-lightbox-index") || "0", 10)));
    });
    document.getElementById("lb-close")?.addEventListener("click", close);
    lb?.addEventListener("click", (e) => { if (e.target === lb) close(); });
    document.addEventListener("keydown", (e) => {
      if (lb.style.display === "none") return;
      if (e.key === "Escape") close();
    });
  }

  init();
  document.addEventListener("astro:page-load", init);
</script>
