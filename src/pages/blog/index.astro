---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageBanner from '../../components/PageBanner.astro';

const posts = (await getCollection('blog', ({ data }) => data.draft !== true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Sandblasting Tips & Industry Insights | Blasting Jack Blog"
  description="Expert advice on sandblasting, rust removal, surface prep, and industrial coatings from Blasting Jack — Michigan's trusted mobile sandblasting professionals since the 1980s."
  canonical="https://blastingjack.com/blog/"
>
  <Header />

  <PageBanner
    label="Knowledge Base"
    title="Sandblasting Tips & Industry Insights"
    subtitle="Practical guidance on surface preparation, rust removal, coatings, and what to expect from professional sandblasting services in Michigan."
  />

  <!-- Post Grid -->
  <section class="max-w-[1400px] mx-auto px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <article class="group flex flex-col bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-300">
            <!-- Color bar -->
            <div class="h-1 bg-primary w-full"></div>

            <div class="flex flex-col flex-1 p-7">
              <!-- Tags -->
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="text-[11px] font-semibold tracking-[0.1em] uppercase text-primary bg-primary/8 px-3 py-1">
                      {tag}
                    </span>
                  ))}
                </div>
              )}

              <!-- Title -->
              <h2 class="font-heading text-[20px] font-semibold leading-[1.3] text-heading mb-3 group-hover:text-primary transition-colors duration-200">
                <a href={`/blog/${post.id}/`} class="stretched-link">
                  {post.data.title}
                </a>
              </h2>

              <!-- Description -->
              <p class="text-body text-[15px] leading-relaxed flex-1 mb-5">
                {post.data.description}
              </p>

              <!-- Meta footer -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100 mt-auto">
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-[13px] text-body/70 font-medium"
                >
                  {formattedDate}
                </time>
                <a
                  href={`/blog/${post.id}/`}
                  class="text-[13px] font-semibold text-primary hover:text-primary-hover transition-colors flex items-center gap-1"
                >
                  Read more <span aria-hidden="true">&rarr;</span>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-primary py-16">
    <div class="max-w-[1400px] mx-auto px-6 text-center">
      <h2 class="font-heading text-[32px] md:text-[40px] font-semibold text-white leading-[1.2] mb-4">
        Ready to Get a Free Estimate?
      </h2>
      <p class="text-white/80 text-[18px] mb-8 max-w-[520px] mx-auto">
        Serving Metro Detroit, Grand Rapids, Lansing, Flint, Kalamazoo, and all of Michigan.
      </p>
      <a
        href="/#contact"
        class="inline-block bg-white text-primary font-semibold text-[17px] px-[40px] py-[16px] border-2 border-white hover:bg-transparent hover:text-white transition-all duration-300"
      >
        Contact Us Today
      </a>
    </div>
  </section>

  <Footer />
</Layout>
