---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const canonical = `https://blastingjack.com/blog/${post.id}/`;
---

<Layout
  title={`${post.data.title} | Blasting Jack`}
  description={post.data.description}
  canonical={canonical}
  ogType="article"
>
  <Header />

  <main class="pt-28 pb-20">
    <!-- Article Header -->
    <div class="bg-[#f7f5f3] py-14 mb-12">
      <div class="max-w-[800px] mx-auto px-6">
        <!-- Tags -->
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-5">
            {post.data.tags.slice(0, 3).map((tag) => (
              <span class="text-[11px] font-semibold tracking-[0.1em] uppercase text-primary bg-primary/10 px-3 py-1">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="font-heading text-[32px] md:text-[44px] font-semibold leading-[1.15] tracking-[-0.025em] text-heading mb-5">
          {post.data.title}
        </h1>

        <div class="flex items-center gap-4 text-[14px] text-body/70">
          <span class="flex items-center gap-1.5">
            <i class="fa-regular fa-calendar"></i>
            <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          </span>
          <span class="text-body/30">|</span>
          <span class="flex items-center gap-1.5">
            <i class="fa-regular fa-user"></i>
            {post.data.author}
          </span>
        </div>
      </div>
    </div>

    <!-- Article Body -->
    <div class="max-w-[800px] mx-auto px-6">
      <div class="prose-content">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-14 pt-8 border-t border-gray-200">
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 text-primary font-semibold hover:text-primary-hover transition-colors"
        >
          <span aria-hidden="true">&larr;</span> Back to all articles
        </a>
      </div>
    </div>
  </main>

  <!-- CTA Banner -->
  <section class="bg-primary py-16">
    <div class="max-w-[1400px] mx-auto px-6 text-center">
      <h2 class="font-heading text-[28px] md:text-[36px] font-semibold text-white leading-[1.2] mb-3">
        Have a Project in Mind?
      </h2>
      <p class="text-white/80 text-[17px] mb-7 max-w-[480px] mx-auto">
        Get a free, no-obligation estimate from Michigan's trusted sandblasting professionals.
      </p>
      <a
        href="/#contact"
        class="inline-block bg-white text-primary font-semibold text-[16px] px-[36px] py-[14px] border-2 border-white hover:bg-transparent hover:text-white transition-all duration-300"
      >
        Get a Free Estimate
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Blog article typography */
  .prose-content {
    color: var(--color-body);
    font-size: 17px;
    line-height: 1.85;
  }
  .prose-content h2 {
    font-family: var(--font-heading);
    font-size: 26px;
    font-weight: 600;
    color: var(--color-heading);
    margin-top: 2.5rem;
    margin-bottom: 0.85rem;
    line-height: 1.25;
  }
  .prose-content h3 {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-heading);
    margin-top: 2rem;
    margin-bottom: 0.65rem;
    line-height: 1.3;
  }
  .prose-content p {
    margin-bottom: 1.3rem;
  }
  .prose-content ul,
  .prose-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.3rem;
  }
  .prose-content ul {
    list-style-type: disc;
  }
  .prose-content ol {
    list-style-type: decimal;
  }
  .prose-content li {
    margin-bottom: 0.5rem;
  }
  .prose-content strong {
    color: var(--color-heading);
    font-weight: 600;
  }
  .prose-content a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-content a:hover {
    color: var(--color-primary-hover);
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid #e5e5e5;
    margin: 2.5rem 0;
  }
  .prose-content blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin-left: 0;
    color: var(--color-heading);
    font-style: italic;
  }
  /* Table styles */
  .prose-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 15px;
  }
  .prose-content th {
    background: #f7f5f3;
    color: var(--color-heading);
    font-weight: 600;
    text-align: left;
    padding: 10px 14px;
    border: 1px solid #e5e5e5;
  }
  .prose-content td {
    padding: 9px 14px;
    border: 1px solid #e5e5e5;
    vertical-align: top;
  }
  .prose-content tr:nth-child(even) td {
    background: #fafaf9;
  }
</style>
