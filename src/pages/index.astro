---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";

import heroBg from "../assets/images/hero-bg.jpg";

// Before/After composites (full originals from WP)
import ba1 from "../assets/images/ba-1.webp";
import ba2 from "../assets/images/ba-2.webp";
import ba3 from "../assets/images/ba-3.webp";
import ba4 from "../assets/images/ba-4.webp";

// Gallery work photos
import galleryWork1 from "../assets/images/gallery-work-1.webp";
import galleryWork2 from "../assets/images/gallery-work-2.webp";
import galleryWork3 from "../assets/images/gallery-work-3.webp";

// Video thumbnails
import vidThumb1 from "../assets/images/video-thumb-1.webp";
import vidThumb2 from "../assets/images/video-thumb-2.webp";
import vidThumb3 from "../assets/images/video-thumb-3.webp";
import vidThumb4 from "../assets/images/video-thumb-4.webp";
import vidThumb5 from "../assets/images/video-thumb-5.webp";
import vidThumb6 from "../assets/images/video-thumb-6.webp";
import vidThumb7 from "../assets/images/video-thumb-7.webp";

// Partners
import partnerEpa from "../assets/images/partner-epa.webp";
import partnerSherwin from "../assets/images/partner-sherwin.webp";
import partnerPpg from "../assets/images/partner-ppg.webp";
import partnerBehr from "../assets/images/partner-behr.webp";
import partnerOleary from "../assets/images/partner-oleary.webp";
import partnerCarboline from "../assets/images/partner-carboline.webp";

const challenges = [
  {
    title: "Corrosion & Wear",
    desc: "Old coatings and rust are deteriorating your valuable equipment over time, leading to expensive repairs.",
    icon: "rust",
  },
  {
    title: "Project Delays",
    desc: "Unreliable contractors and slow work processes are delaying your project timelines, harming your business.",
    icon: "clock",
  },
  {
    title: "Safety & Quality Concerns",
    desc: "Improper preparation and low-quality work can lead to safety issues and coatings that don't last long-term.",
    icon: "shield",
  },
];

const services = [
  { title: "Mobile Blasting", desc: "Our fully-equipped mobile teams travel directly to your site to perform the work on-location." },
  { title: "Durable Coatings", desc: "After preparing the surface, we apply high-quality industrial coatings to protect it from corrosion and wear." },
  { title: "On-Site Setup", desc: "We begin every project by professionally preparing the worksite in full compliance with all safety standards." },
  { title: "Fast Turnaround", desc: "We value your time and complete our projects efficiently and within the agreed-upon deadlines." },
];

const whyUs = [
  { title: "Decades of Experience", desc: "As a family-owned business operating since the 1980s, we approach every project with deep knowledge and experience.", num: "01" },
  { title: "Safety-First Approach", desc: "Our team strictly adheres to all safety standards, ensuring the protection of your site and our employees.", num: "02" },
  { title: "Uncompromising Quality", desc: "We use only the best materials and proven technologies to guarantee a long-lasting and durable result.", num: "03" },
  { title: "On-Time, Every Time", desc: "We value your time and complete our projects within the agreed-upon deadlines, without disrupting your business.", num: "04" },
  { title: "A Single, Reliable Partner", desc: "By handling all the work in-house, from surface preparation to the final coating, we simplify the process for you.", num: "05" },
  { title: "Honesty & Integrity", desc: "Open communication and transparent pricing are the foundation of our business. We work to earn your trust.", num: "06" },
];

const processSteps = [
  { num: "01", title: "Consultation & Planning" },
  { num: "02", title: "Preparation & Blasting" },
  { num: "03", title: "Coating Application" },
  { num: "04", title: "Final Inspection & Aftercare" },
];

const beforeAfterImages = [
  { src: ba1, alt: "Industrial pipe restoration - before and after" },
  { src: ba2, alt: "Pole base repair and coating - before and after" },
  { src: ba3, alt: "Structural steel restoration - before and after" },
  { src: ba4, alt: "Tank interior coating - before and after" },
];

const galleryImages = [
  { src: galleryWork1, alt: "Sandblasting project - industrial equipment" },
  { src: galleryWork2, alt: "Surface preparation - on site work" },
  { src: galleryWork3, alt: "Completed coating project" },
  { src: ba1, alt: "Industrial pipe restoration - before and after" },
  { src: ba2, alt: "Pole base repair - before and after" },
  { src: ba3, alt: "Structural steel - before and after" },
  { src: ba4, alt: "Tank interior - before and after" },
];

const videos = [
  { thumb: vidThumb1, id: "1120712630", title: "Sandblasting in action" },
  { thumb: vidThumb2, id: "1120714635", title: "Surface preparation" },
  { thumb: vidThumb3, id: "1120714441", title: "Industrial coating" },
  { thumb: vidThumb4, id: "1120714419", title: "Mobile blasting setup" },
  { thumb: vidThumb5, id: "1120714364", title: "Team at work" },
  { thumb: vidThumb6, id: "1120714142", title: "Project walkthrough" },
  { thumb: vidThumb7, id: "1120712630", title: "Finishing touches" },
];

const partners = [
  { src: partnerEpa, alt: "EPA", w: 175, h: 115 },
  { src: partnerSherwin, alt: "Sherwin Williams", w: 175, h: 87 },
  { src: partnerPpg, alt: "PPG", w: 175, h: 193 },
  { src: partnerBehr, alt: "Behr", w: 175, h: 44 },
  { src: partnerOleary, alt: "O'Leary", w: 175, h: 69 },
  { src: partnerCarboline, alt: "Carboline", w: 175, h: 64 },
];
---

<Layout>
  <Header />

  <!-- Hero -->
  <section class="relative min-h-[600px] md:min-h-[700px] flex items-center overflow-hidden">
    <Image
      src={heroBg}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 max-w-[1400px] mx-auto px-6 py-32 md:py-40 w-full text-center">
      <h1 class="font-heading text-[40px] md:text-[60px] lg:text-[80px] font-semibold leading-[1.1] tracking-[-0.045em] max-w-[900px] mx-auto reveal" style="color: #ffffff;">
        Restoring Surfaces, Protecting Your Assets
      </h1>
      <p class="text-white text-[18px] md:text-[20px] mt-6 max-w-[600px] mx-auto reveal" style="transition-delay:150ms">
        Your trusted partner for mobile sandblasting and surface preparation services in Michigan.
      </p>
      <a
        href="#contact"
        class="inline-block mt-8 bg-primary text-white font-semibold text-[18px] md:text-[20px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-primary hover:bg-primary-hover hover:border-primary-hover transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 reveal"
        style="transition-delay:300ms"
      >
        Get a Free Estimate
      </a>
    </div>
  </section>

  <!-- Challenges -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <div class="reveal-left">
          <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em]">
            We Understand Your Challenges
          </h2>
          <p class="text-body mt-6">
            We know that industrial projects come with a unique set of challenges. From protecting valuable assets to meeting tight deadlines, you need a partner who understands what's at stake.
          </p>
          <a
            href="#contact"
            class="inline-block mt-8 bg-primary text-white font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-primary hover:bg-primary-hover hover:border-primary-hover transition-all duration-300 hover:shadow-lg hover:shadow-primary/25"
          >
            Get a Free Estimate
          </a>
        </div>
        <div class="space-y-6 stagger-children">
          {challenges.map((item) => (
            <div class="bg-white border border-gray-100 p-6 flex gap-5 items-start shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
              <div class="w-12 h-12 bg-dark flex items-center justify-center shrink-0">
                {item.icon === "rust" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m14.5 9-5 5"/><path d="m9.5 9 5 5"/></svg>
                )}
                {item.icon === "clock" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                )}
                {item.icon === "shield" && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                )}
              </div>
              <div>
                <h3 class="font-heading text-[20px] font-semibold text-heading">{item.title}</h3>
                <p class="text-body text-[16px] mt-2">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-16 md:py-24 bg-light-bg">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        Our Solution &ndash; Our Services
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-12 stagger-children">
        {services.map((svc) => (
          <div class="bg-white p-8 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group rounded-lg">
            <div class="w-16 h-16 mx-auto mb-6 bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors duration-300 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6B2813" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <h3 class="font-heading text-[20px] font-semibold text-heading">{svc.title}</h3>
            <p class="text-body text-[16px] mt-3">{svc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery (work photos + before/after) with lightbox -->
  <section id="gallery" class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        Our Recent Work
      </h2>
      <p class="text-body text-center mt-4 max-w-[600px] mx-auto reveal" style="transition-delay:100ms">
        Click any image to view full size.
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-12 stagger-children">
        {galleryImages.map((img, i) => (
          <button
            type="button"
            class="overflow-hidden rounded-lg group cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary/50"
            data-lightbox-trigger
            data-lightbox-index={i}
          >
            <Image
              src={img.src}
              alt={img.alt}
              width={700}
              height={467}
              class="w-full aspect-[3/2] object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
            />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox-overlay" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox">
    <button class="absolute top-5 right-5 text-white/70 hover:text-white transition-colors z-10 p-2" id="lightbox-close" aria-label="Close lightbox">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 p-2" id="lightbox-prev" aria-label="Previous image">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors z-10 p-2" id="lightbox-next" aria-label="Next image">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <img id="lightbox-img" src="" alt="" />
  </div>

  <!-- Team Videos Carousel -->
  <section class="py-16 md:py-24 bg-light-bg overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        See Our Team in Action
      </h2>
      <div class="relative mt-12 reveal" style="transition-delay:150ms">
        <!-- Carousel controls -->
        <button id="vid-prev" class="absolute -left-2 md:left-0 top-1/2 -translate-y-1/2 z-10 w-11 h-11 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center transition-all duration-200 hover:scale-110" aria-label="Previous videos">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button id="vid-next" class="absolute -right-2 md:right-0 top-1/2 -translate-y-1/2 z-10 w-11 h-11 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center transition-all duration-200 hover:scale-110" aria-label="Next videos">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <!-- Carousel viewport -->
        <div class="overflow-hidden mx-6 md:mx-12 rounded-lg" id="vid-carousel">
          <div class="carousel-track gap-4" id="vid-track">
            {videos.map((vid) => (
              <div
                class="w-[200px] md:w-[240px] relative aspect-[9/16] overflow-hidden rounded-lg group cursor-pointer shrink-0"
                data-vimeo-id={vid.id}
                data-video-trigger
              >
                <Image
                  src={vid.thumb}
                  alt={vid.title}
                  width={240}
                  height={427}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-out"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent group-hover:from-black/30 transition-all duration-300 flex items-center justify-center">
                  <div class="relative w-14 h-14 rounded-full bg-white/90 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 play-pulse">
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="#333" class="ml-1"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Modal -->
  <div id="video-modal" class="fixed inset-0 z-[100] items-center justify-center bg-black/85 backdrop-blur-sm" style="display:none">
    <button id="modal-close" class="absolute top-6 right-6 text-white/80 hover:text-white transition-colors z-10" aria-label="Close video">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="w-full max-w-[400px] mx-4" style="aspect-ratio:9/16">
      <iframe
        id="vimeo-iframe"
        class="w-full h-full rounded-lg"
        src=""
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <!-- Why Choose -->
  <section id="whyus" class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        Why Choose Blasting Jack
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12 stagger-children">
        {whyUs.map((item) => (
          <div class="bg-light-bg p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 rounded-lg group">
            <span class="font-heading text-[14px] font-bold text-primary tracking-wider">{item.num}</span>
            <h3 class="font-heading text-[20px] font-semibold text-heading mt-3 group-hover:text-primary transition-colors duration-300">{item.title}</h3>
            <p class="text-body text-[16px] mt-3">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 md:py-20 bg-light-bg">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        Our Partners & Valued Clients
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16 mt-12 reveal" style="transition-delay:150ms">
        {partners.map((p) => (
          <div class="grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100">
            <Image src={p.src} alt={p.alt} width={p.w} height={p.h} class="h-[50px] md:h-[70px] w-auto object-contain" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-[1400px] mx-auto px-6">
      <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] text-center reveal">
        From Rust to Ready: Our 4-Step Process
      </h2>
      <div class="w-20 h-[2px] bg-dark mx-auto mt-6"></div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-14 stagger-children">
        {processSteps.map((step) => (
          <div class="text-center group">
            <span class="font-heading text-[48px] md:text-[60px] font-bold text-dark/10 leading-none group-hover:text-primary/20 transition-colors duration-300">{step.num}</span>
            <h3 class="font-heading text-[18px] md:text-[20px] font-semibold text-heading mt-2">{step.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-16 md:py-24 bg-light-bg">
    <div class="max-w-[1400px] mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
        <div class="reveal-left">
          <h2 class="font-heading text-[32px] md:text-[48px] font-medium leading-[1.2] tracking-[-0.045em] capitalize">
            Get a quote
          </h2>
          <p class="text-body mt-4">
            Please contact us regarding your project and we will get back to you shortly.
          </p>
          <div class="mt-8 space-y-4">
            <a href="mailto:info@blastingjack.com" class="flex items-center gap-3 text-body hover:text-primary transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              info@blastingjack.com
            </a>
            <span class="flex items-center gap-3 text-body">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              810-602-6809
            </span>
          </div>
          <div class="flex gap-3 mt-8">
            <a href="#" class="w-10 h-10 rounded-full bg-dark/10 hover:bg-primary hover:text-white flex items-center justify-center transition-all duration-300 text-dark hover:scale-110" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-dark/10 hover:bg-primary hover:text-white flex items-center justify-center transition-all duration-300 text-dark hover:scale-110" aria-label="Twitter">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-dark/10 hover:bg-primary hover:text-white flex items-center justify-center transition-all duration-300 text-dark hover:scale-110" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
            <a href="#" class="w-10 h-10 rounded-full bg-dark/10 hover:bg-primary hover:text-white flex items-center justify-center transition-all duration-300 text-dark hover:scale-110" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          </div>
        </div>

        <form class="space-y-5 reveal-right" action="#" method="POST">
          <div>
            <label for="name" class="block text-[14px] font-medium text-heading mb-1">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Theo James" class="w-full px-4 py-3 border border-gray-200 bg-white text-[16px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-300 rounded-md" />
          </div>
          <div>
            <label for="email" class="block text-[14px] font-medium text-heading mb-1">Email address</label>
            <input type="email" id="email" name="email" placeholder="theojames@gmail.com" class="w-full px-4 py-3 border border-gray-200 bg-white text-[16px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-300 rounded-md" />
          </div>
          <div>
            <label for="phone" class="block text-[14px] font-medium text-heading mb-1">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="(500) 234-5678" class="w-full px-4 py-3 border border-gray-200 bg-white text-[16px] focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-300 rounded-md" />
          </div>
          <div>
            <label for="message" class="block text-[14px] font-medium text-heading mb-1">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us more about your project." class="w-full px-4 py-3 border border-gray-200 bg-white text-[16px] resize-none focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all duration-300 rounded-md"></textarea>
          </div>
          <button type="submit" class="w-full bg-primary text-white font-semibold text-[18px] py-4 hover:bg-primary-hover transition-all duration-300 hover:shadow-lg hover:shadow-primary/25 rounded-md">
            Submit
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- CTA Bar -->
  <section class="py-12 md:py-16" style="background-color: #1a1a1a;">
    <div class="max-w-[1400px] mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <h2 class="font-heading text-[32px] md:text-[50px] font-medium leading-[1.2] tracking-[-0.045em] reveal-left" style="color: #ffffff;">
        We Blast, We Coat, You Relax.
      </h2>
      <a
        href="#contact"
        class="inline-block bg-white text-black font-semibold text-[18px] px-[40px] md:px-[60px] py-[18px] md:py-[20px] border-2 border-white hover:bg-transparent hover:text-white transition-all duration-300 shrink-0 reveal-right"
      >
        Get a Free Estimate
      </a>
    </div>
  </section>

  <Footer />

  <!-- Back to Top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>
</Layout>

<script>
  function initAll() {
    // Intersection Observer for scroll reveals
    const revealObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            revealObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document.querySelectorAll(".reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children").forEach((el) => {
      revealObs.observe(el);
    });

    // Gallery Lightbox
    const lightbox = document.getElementById("lightbox") as HTMLElement;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const triggers = document.querySelectorAll("[data-lightbox-trigger]");
    const srcs: string[] = [];
    triggers.forEach((t) => {
      const img = t.querySelector("img");
      if (img) srcs.push(img.src);
    });
    let currentLb = 0;

    function openLightbox(i: number) {
      currentLb = i;
      lbImg.src = srcs[i] || "";
      lightbox.classList.add("active");
      document.body.style.overflow = "hidden";
    }
    function closeLightbox() {
      lightbox.classList.remove("active");
      document.body.style.overflow = "";
    }

    triggers.forEach((t) => {
      t.addEventListener("click", () => {
        const idx = parseInt(t.getAttribute("data-lightbox-index") || "0", 10);
        openLightbox(idx);
      });
    });
    document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
    document.getElementById("lightbox-prev")?.addEventListener("click", () => {
      openLightbox((currentLb - 1 + srcs.length) % srcs.length);
    });
    document.getElementById("lightbox-next")?.addEventListener("click", () => {
      openLightbox((currentLb + 1) % srcs.length);
    });
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Video Carousel
    const track = document.getElementById("vid-track") as HTMLElement;
    const prevBtn = document.getElementById("vid-prev");
    const nextBtn = document.getElementById("vid-next");
    let carouselPos = 0;

    function getSlideWidth() {
      const firstSlide = track?.firstElementChild as HTMLElement;
      if (!firstSlide) return 260;
      return firstSlide.offsetWidth + 16; // width + gap
    }
    function getMaxOffset() {
      if (!track) return 0;
      const viewport = track.parentElement!.offsetWidth;
      const total = track.scrollWidth;
      return Math.max(0, total - viewport);
    }
    function updateCarousel() {
      if (!track) return;
      track.style.transform = `translateX(-${carouselPos}px)`;
    }

    prevBtn?.addEventListener("click", () => {
      carouselPos = Math.max(0, carouselPos - getSlideWidth() * 2);
      updateCarousel();
    });
    nextBtn?.addEventListener("click", () => {
      carouselPos = Math.min(getMaxOffset(), carouselPos + getSlideWidth() * 2);
      updateCarousel();
    });

    // Touch swipe for carousel
    let touchStartX = 0;
    let touchDiff = 0;
    track?.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener("touchmove", (e) => { touchDiff = touchStartX - e.touches[0].clientX; }, { passive: true });
    track?.addEventListener("touchend", () => {
      if (Math.abs(touchDiff) > 50) {
        if (touchDiff > 0) {
          carouselPos = Math.min(getMaxOffset(), carouselPos + getSlideWidth() * 2);
        } else {
          carouselPos = Math.max(0, carouselPos - getSlideWidth() * 2);
        }
        updateCarousel();
      }
      touchDiff = 0;
    });

    // Video Modal
    const modal = document.getElementById("video-modal") as HTMLElement;
    const iframe = document.getElementById("vimeo-iframe") as HTMLIFrameElement;

    function closeVideoModal() {
      if (!modal || !iframe) return;
      modal.style.display = "none";
      iframe.src = "";
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-video-trigger]").forEach((el) => {
      el.addEventListener("click", () => {
        const vimeoId = el.getAttribute("data-vimeo-id");
        if (!modal || !iframe || !vimeoId) return;
        iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&portrait=0&byline=0`;
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
      });
    });
    document.getElementById("modal-close")?.addEventListener("click", closeVideoModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeVideoModal(); });

    // Keyboard: Escape closes everything, arrows navigate lightbox
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeLightbox();
        closeVideoModal();
      }
      if (lightbox.classList.contains("active")) {
        if (e.key === "ArrowLeft") openLightbox((currentLb - 1 + srcs.length) % srcs.length);
        if (e.key === "ArrowRight") openLightbox((currentLb + 1) % srcs.length);
      }
    });

    // Header scroll shadow
    const header = document.getElementById("site-header");
    window.addEventListener("scroll", () => {
      if (!header) return;
      if (window.scrollY > 100) header.classList.add("shadow-md");
      else header.classList.remove("shadow-md");
    }, { passive: true });

    // Back to top
    const btt = document.getElementById("back-to-top");
    window.addEventListener("scroll", () => {
      if (!btt) return;
      if (window.scrollY > 600) btt.classList.add("show");
      else btt.classList.remove("show");
    }, { passive: true });
    btt?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>
