  </button>
</Layout>

<script>
  function initAll() {
    // Intersection Observer for scroll reveals
    const revealObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            revealObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );
    document.querySelectorAll(".reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children").forEach((el) => {
      revealObs.observe(el);
    });

    // Before/After Sliders
    document.querySelectorAll("[data-ba-slider]").forEach((slider) => {
      const afterEl = slider.querySelector(".ba-after") as HTMLElement;
      const handle = slider.querySelector(".ba-handle") as HTMLElement;
      if (!afterEl || !handle) return;

      let isDragging = false;

      function updateSlider(x: number) {
        const rect = slider.getBoundingClientRect();
        let pct = ((x - rect.left) / rect.width) * 100;
        pct = Math.max(2, Math.min(98, pct));
        afterEl.style.clipPath = `inset(0 0 0 ${pct}%)`;
        handle.style.left = `${pct}%`;
      }

      slider.addEventListener("mousedown", (e: Event) => {
        isDragging = true;
        updateSlider((e as MouseEvent).clientX);
      });
      document.addEventListener("mousemove", (e: MouseEvent) => {
        if (isDragging) updateSlider(e.clientX);
      });
      document.addEventListener("mouseup", () => { isDragging = false; });

      slider.addEventListener("touchstart", (e: Event) => {
        isDragging = true;
        updateSlider((e as TouchEvent).touches[0].clientX);
      }, { passive: true });
      document.addEventListener("touchmove", (e: TouchEvent) => {
        if (isDragging) updateSlider(e.touches[0].clientX);
      }, { passive: true });
      document.addEventListener("touchend", () => { isDragging = false; });
    });

    // Work Carousel (thumbnail strip)
    const workTrack = document.getElementById("work-track") as HTMLElement;
    let workPos = 0;

    function getWorkSlideWidth() {
      const firstSlide = workTrack?.firstElementChild as HTMLElement;
      if (!firstSlide) return 336;
      return firstSlide.offsetWidth + 16;
    }
    function getWorkMaxOffset() {
      if (!workTrack) return 0;
      const viewport = workTrack.parentElement!.offsetWidth;
      return Math.max(0, workTrack.scrollWidth - viewport);
    }
    function updateWorkCarousel() {
      if (!workTrack) return;
      workTrack.style.transform = `translateX(-${workPos}px)`;
    }

    function advanceWork() {
      const max = getWorkMaxOffset();
      if (workPos >= max) {
        workPos = 0;
      } else {
        workPos = Math.min(max, workPos + getWorkSlideWidth());
      }
      updateWorkCarousel();
    }

    let workAutoplay = setInterval(advanceWork, 3500);
    function resetWorkAutoplay() {
      clearInterval(workAutoplay);
      workAutoplay = setInterval(advanceWork, 3500);
    }

    document.getElementById("work-prev")?.addEventListener("click", () => {
      workPos = Math.max(0, workPos - getWorkSlideWidth() * 2);
      updateWorkCarousel();
      resetWorkAutoplay();
    });
    document.getElementById("work-next")?.addEventListener("click", () => {
      workPos = Math.min(getWorkMaxOffset(), workPos + getWorkSlideWidth() * 2);
      updateWorkCarousel();
      resetWorkAutoplay();
    });

    // Pause autoplay on hover
    workTrack?.addEventListener("mouseenter", () => clearInterval(workAutoplay));
    workTrack?.addEventListener("mouseleave", () => { workAutoplay = setInterval(advanceWork, 3500); });

    // Touch swipe for work carousel
    let workTouchStartX = 0;
    let workTouchDiff = 0;
    workTrack?.addEventListener("touchstart", (e) => { workTouchStartX = e.touches[0].clientX; }, { passive: true });
    workTrack?.addEventListener("touchmove", (e) => { workTouchDiff = workTouchStartX - e.touches[0].clientX; }, { passive: true });
    workTrack?.addEventListener("touchend", () => {
      if (Math.abs(workTouchDiff) > 50) {
        if (workTouchDiff > 0) {
          workPos = Math.min(getWorkMaxOffset(), workPos + getWorkSlideWidth() * 2);
        } else {
          workPos = Math.max(0, workPos - getWorkSlideWidth() * 2);
        }
        updateWorkCarousel();
        resetWorkAutoplay();
      }
      workTouchDiff = 0;
    });

    // Before/After Modal
    const baModal = document.getElementById("ba-modal") as HTMLElement;
    const baSlides = document.querySelectorAll("[data-ba-slide]");

    function openBaModal(index: number) {
      baSlides.forEach((s, i) => {
        (s as HTMLElement).style.display = i === index ? "block" : "none";
      });
      baModal?.classList.add("active");
      document.body.style.overflow = "hidden";
    }
    function closeBaModal() {
      baModal?.classList.remove("active");
      document.body.style.overflow = "";
      baSlides.forEach((s) => {
        const afterEl = s.querySelector(".ba-after") as HTMLElement;
        const handle = s.querySelector(".ba-handle") as HTMLElement;
        if (afterEl) afterEl.style.clipPath = "inset(0 0 0 50%)";
        if (handle) handle.style.left = "50%";
      });
    }

    document.querySelectorAll("[data-ba-open]").forEach((el) => {
      el.addEventListener("click", () => {
        const idx = parseInt(el.getAttribute("data-ba-open") || "0", 10);
        openBaModal(idx);
      });
    });
    document.getElementById("ba-modal-close")?.addEventListener("click", closeBaModal);
    baModal?.addEventListener("click", (e) => { if (e.target === baModal) closeBaModal(); });

    // Gallery Lightbox
    const lightbox = document.getElementById("lightbox") as HTMLElement;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const triggers = document.querySelectorAll("[data-lightbox-trigger]");
    const srcs: string[] = [];
    triggers.forEach((t) => {
      const img = t.querySelector("img");
      if (img) srcs.push(img.src);
    });
    let currentLb = 0;

    function openLightbox(i: number) {
      currentLb = i;
      lbImg.src = srcs[i] || "";
      lightbox.classList.add("active");
      document.body.style.overflow = "hidden";
    }
    function closeLightbox() {
      lightbox.classList.remove("active");
      document.body.style.overflow = "";
    }

    triggers.forEach((t) => {
      t.addEventListener("click", () => {
        const idx = parseInt(t.getAttribute("data-lightbox-index") || "0", 10);
        openLightbox(idx);
      });
    });
    document.getElementById("lightbox-close")?.addEventListener("click", closeLightbox);
    document.getElementById("lightbox-prev")?.addEventListener("click", () => {
      openLightbox((currentLb - 1 + srcs.length) % srcs.length);
    });
    document.getElementById("lightbox-next")?.addEventListener("click", () => {
      openLightbox((currentLb + 1) % srcs.length);
    });
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Video Carousel
    const track = document.getElementById("vid-track") as HTMLElement;
    const prevBtn = document.getElementById("vid-prev");
    const nextBtn = document.getElementById("vid-next");
    let carouselPos = 0;

    function getSlideWidth() {
      const firstSlide = track?.firstElementChild as HTMLElement;
      if (!firstSlide) return 260;
      return firstSlide.offsetWidth + 16; // width + gap
    }
    function getMaxOffset() {
      if (!track) return 0;
      const viewport = track.parentElement!.offsetWidth;
      const total = track.scrollWidth;
      return Math.max(0, total - viewport);
    }
    function updateCarousel() {
      if (!track) return;
      track.style.transform = `translateX(-${carouselPos}px)`;
    }

    prevBtn?.addEventListener("click", () => {
      carouselPos = Math.max(0, carouselPos - getSlideWidth() * 2);
      updateCarousel();
    });
    nextBtn?.addEventListener("click", () => {
      carouselPos = Math.min(getMaxOffset(), carouselPos + getSlideWidth() * 2);
      updateCarousel();
    });

    // Touch swipe for carousel
    let touchStartX = 0;
    let touchDiff = 0;
    track?.addEventListener("touchstart", (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener("touchmove", (e) => { touchDiff = touchStartX - e.touches[0].clientX; }, { passive: true });
    track?.addEventListener("touchend", () => {
      if (Math.abs(touchDiff) > 50) {
        if (touchDiff > 0) {
          carouselPos = Math.min(getMaxOffset(), carouselPos + getSlideWidth() * 2);
        } else {
          carouselPos = Math.max(0, carouselPos - getSlideWidth() * 2);
        }
        updateCarousel();
      }
      touchDiff = 0;
    });

    // Video Modal
    const modal = document.getElementById("video-modal") as HTMLElement;
    const iframe = document.getElementById("vimeo-iframe") as HTMLIFrameElement;

    function closeVideoModal() {
      if (!modal || !iframe) return;
      modal.style.display = "none";
      iframe.src = "";
      document.body.style.overflow = "";
    }

    document.querySelectorAll("[data-video-trigger]").forEach((el) => {
      el.addEventListener("click", () => {
        const vimeoId = el.getAttribute("data-vimeo-id");
        if (!modal || !iframe || !vimeoId) return;
        iframe.src = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&title=0&portrait=0&byline=0`;
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
      });
    });
    document.getElementById("modal-close")?.addEventListener("click", closeVideoModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeVideoModal(); });

    // Keyboard: Escape closes everything, arrows navigate lightbox
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        closeLightbox();
        closeVideoModal();
        closeBaModal();
      }
      if (lightbox.classList.contains("active")) {
        if (e.key === "ArrowLeft") openLightbox((currentLb - 1 + srcs.length) % srcs.length);
        if (e.key === "ArrowRight") openLightbox((currentLb + 1) % srcs.length);
      }
    });

    // Header scroll shadow
    const header = document.getElementById("site-header");
    window.addEventListener("scroll", () => {
      if (!header) return;
      if (window.scrollY > 100) header.classList.add("shadow-md");
      else header.classList.remove("shadow-md");
    }, { passive: true });

    // Back to top
    const btt = document.getElementById("back-to-top");
    window.addEventListener("scroll", () => {
      if (!btt) return;
      if (window.scrollY > 600) btt.classList.add("show");
      else btt.classList.remove("show");
    }, { passive: true });
    btt?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // Contact form — Web3Forms AJAX submission
    const contactForm = document.getElementById("contact-form") as HTMLFormElement;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const formResult = document.getElementById("form-result") as HTMLElement;

    contactForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
      formResult.className = "hidden text-center text-[15px] font-medium py-3 px-4 rounded-md";

      const formData = new FormData(contactForm);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json",
          },
          body: json,
        });
        const result = await response.json();

        formResult.classList.remove("hidden");
        if (response.status === 200) {
          formResult.textContent = "Message sent! We'll be in touch shortly.";
          formResult.classList.add("bg-green-50", "text-green-700", "border", "border-green-200");
          contactForm.reset();
        } else {
          formResult.textContent = result.message ?? "Something went wrong. Please try again.";
          formResult.classList.add("bg-red-50", "text-red-700", "border", "border-red-200");
        }
      } catch {
        formResult.classList.remove("hidden");
        formResult.textContent = "Network error. Please try again or call us directly.";
        formResult.classList.add("bg-red-50", "text-red-700", "border", "border-red-200");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Message";
        setTimeout(() => {
          formResult.classList.add("hidden");
          formResult.className = "hidden text-center text-[15px] font-medium py-3 px-4 rounded-md";
        }, 6000);
      }
    });
  }

  initAll();
  document.addEventListener("astro:page-load", initAll);
</script>
