---
import { Image } from "astro:assets";
import logo from "../assets/images/logo-full.png";

const services = [
  { label: "Mobile Sandblasting", href: "/services/mobile-sandblasting/" },
  { label: "Abrasive Blasting", href: "/services/abrasive-blasting/" },
  { label: "Industrial Sandblasting", href: "/services/industrial-sandblasting/" },
  { label: "Vapor / Dustless Blasting", href: "/services/vapor-dustless-blasting/" },
  { label: "Dry Ice Blasting", href: "/services/dry-ice-blasting/" },
  { label: "Coating Removal", href: "/services/coating-removal/" },
  { label: "Rust Removal", href: "/services/rust-removal/" },
  { label: "Steel Surface Preparation", href: "/services/steel-surface-preparation/" },
  { label: "Equipment Blasting", href: "/services/equipment-blasting/" },
  { label: "Tank & Silo Blasting", href: "/services/tank-silo-blasting/" },
  { label: "Structural Steel Blasting", href: "/services/structural-steel-blasting/" },
  { label: "Brick & Masonry Blasting", href: "/services/brick-masonry-blasting/" },
  { label: "Parking Garage Surface Prep", href: "/services/parking-garage-surface-preparation/" },
  { label: "Surface Prep for Coatings", href: "/services/surface-preparation-for-coatings/" },
];

const industries = [
  { label: "Steel Fabricators", href: "/industries/steel-fabricators/" },
  { label: "Manufacturing Plants", href: "/industries/manufacturing-plants/" },
  { label: "Equipment Rental Fleets", href: "/industries/equipment-rental-fleets/" },
  { label: "Tanks & Silos", href: "/industries/tanks-silos/" },
  { label: "Structural Steel", href: "/industries/structural-steel/" },
  { label: "Parking Garages", href: "/industries/parking-garages/" },
  { label: "Industrial Equipment", href: "/industries/industrial-equipment/" },
  { label: "General Contractors", href: "/industries/general-contractors/" },
  { label: "Property Managers", href: "/industries/property-managers/" },
  { label: "Municipal / Utility Assets", href: "/industries/municipal-utility-assets/" },
  { label: "Historic Restoration", href: "/industries/historic-restoration/" },
  { label: "Plant Maintenance", href: "/industries/plant-maintenance/" },
];

const areas = [
  { label: "Macomb County", href: "/areas-served/macomb-county-mobile-sandblasting/" },
  { label: "Oakland County", href: "/areas-served/oakland-county-mobile-sandblasting/" },
  { label: "Wayne County", href: "/areas-served/wayne-county-mobile-sandblasting/" },
  { label: "Washtenaw County", href: "/areas-served/washtenaw-county-mobile-sandblasting/" },
  { label: "Genesee County", href: "/areas-served/genesee-county-mobile-sandblasting/" },
  { label: "Livingston County", href: "/areas-served/livingston-county-mobile-sandblasting/" },
  { label: "St. Clair County", href: "/areas-served/st-clair-county-mobile-sandblasting/" },
  { label: "Monroe County", href: "/areas-served/monroe-county-mobile-sandblasting/" },
  { label: "Lapeer County", href: "/areas-served/lapeer-county-mobile-sandblasting/" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-all" id="site-header">
  <nav class="max-w-[1400px] mx-auto flex items-center justify-between px-6 py-3">
    <a href="/" class="shrink-0">
      <Image src={logo} alt="Blasting Jack" width={111} height={85} class="h-[85px] w-auto" />
    </a>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      class="lg:hidden flex flex-col gap-[6px] p-2"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-[2px] bg-dark transition-all origin-center" id="bar1"></span>
      <span class="block w-6 h-[2px] bg-dark transition-all" id="bar2"></span>
      <span class="block w-6 h-[2px] bg-dark transition-all origin-center" id="bar3"></span>
    </button>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-6">
      <ul class="flex items-center gap-1 font-nav text-[16px] font-medium text-dark">

        <!-- Services dropdown -->
        <li class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 hover:text-primary transition-colors rounded">
            Services
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 transition-transform group-hover:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <!-- Mega dropdown — 2 cols -->
          <div class="hidden group-hover:block absolute top-full left-0 pt-1 z-[100]">
            <div class="bg-white border border-gray-200 shadow-xl rounded-b-lg min-w-[520px] p-4">
              <p class="text-[11px] font-semibold text-body/50 uppercase tracking-[0.12em] mb-3 px-1">Blasting Services</p>
              <div class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                {services.map(s => (
                  <a href={s.href} class="block px-2 py-1.5 text-[14px] text-body hover:text-primary hover:bg-light-bg rounded transition-colors">
                    {s.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <!-- Industries dropdown -->
        <li class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 hover:text-primary transition-colors rounded">
            Industries
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 transition-transform group-hover:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="hidden group-hover:block absolute top-full left-0 pt-1 z-[100]">
            <div class="bg-white border border-gray-200 shadow-xl rounded-b-lg min-w-[280px] p-4">
              <p class="text-[11px] font-semibold text-body/50 uppercase tracking-[0.12em] mb-3 px-1">Industries & Assets</p>
              <div class="flex flex-col gap-0.5">
                {industries.map(i => (
                  <a href={i.href} class="block px-2 py-1.5 text-[14px] text-body hover:text-primary hover:bg-light-bg rounded transition-colors">
                    {i.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <!-- Areas Served dropdown -->
        <li class="relative group">
          <button class="flex items-center gap-1 px-3 py-2 hover:text-primary transition-colors rounded">
            Areas Served
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 transition-transform group-hover:rotate-180"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="hidden group-hover:block absolute top-full left-0 pt-1 z-[100]">
            <div class="bg-white border border-gray-200 shadow-xl rounded-b-lg min-w-[240px] p-4">
              <p class="text-[11px] font-semibold text-body/50 uppercase tracking-[0.12em] mb-3 px-1">Michigan Counties</p>
              <div class="flex flex-col gap-0.5">
                {areas.map(a => (
                  <a href={a.href} class="block px-2 py-1.5 text-[14px] text-body hover:text-primary hover:bg-light-bg rounded transition-colors">
                    {a.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </li>

        <li><a href="/gallery/" class="px-3 py-2 hover:text-primary transition-colors block">Gallery</a></li>
        <li><a href="/blog/" class="px-3 py-2 hover:text-primary transition-colors block">Blog</a></li>
        <li><a href="/#contact" class="px-3 py-2 hover:text-primary transition-colors block">Contact</a></li>
      </ul>

      <a
        href="/#contact"
        class="inline-block bg-primary text-white font-semibold text-[15px] px-[20px] py-[13px] border-2 border-primary hover:bg-primary-hover transition-colors whitespace-nowrap shrink-0"
      >
        Get a Free Estimate
      </a>
    </div>
  </nav>
</header>

<!-- Mobile nav overlay -->
<div
  id="mobile-nav"
  class="hidden fixed inset-0 top-[97px] z-[200] flex-col lg:hidden overflow-y-auto"
  style="background: #ffffff;"
>
  <div class="p-6 space-y-1 font-nav text-[17px] font-medium text-dark">

    <!-- Services accordion -->
    <div class="border-b border-gray-100">
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between py-3 hover:text-primary transition-colors"
        aria-expanded="false"
      >
        <span>Services</span>
        <svg class="accordion-icon w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-panel hidden pb-3 pl-4 space-y-1">
        {services.map(s => (
          <a href={s.href} class="block py-2 text-[15px] text-body hover:text-primary transition-colors">
            {s.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Industries accordion -->
    <div class="border-b border-gray-100">
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between py-3 hover:text-primary transition-colors"
        aria-expanded="false"
      >
        <span>Industries</span>
        <svg class="accordion-icon w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-panel hidden pb-3 pl-4 space-y-1">
        {industries.map(i => (
          <a href={i.href} class="block py-2 text-[15px] text-body hover:text-primary transition-colors">
            {i.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Areas Served accordion -->
    <div class="border-b border-gray-100">
      <button
        class="mobile-accordion-btn w-full flex items-center justify-between py-3 hover:text-primary transition-colors"
        aria-expanded="false"
      >
        <span>Areas Served</span>
        <svg class="accordion-icon w-4 h-4 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="mobile-accordion-panel hidden pb-3 pl-4 space-y-1">
        {areas.map(a => (
          <a href={a.href} class="block py-2 text-[15px] text-body hover:text-primary transition-colors">
            {a.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Direct links -->
    <a href="/gallery/" class="block py-3 border-b border-gray-100 hover:text-primary transition-colors">Gallery</a>
    <a href="/blog/" class="block py-3 border-b border-gray-100 hover:text-primary transition-colors">Blog</a>
    <a href="/#contact" class="block py-3 hover:text-primary transition-colors">Contact</a>

    <div class="pt-4">
      <a
        href="/#contact"
        class="inline-block w-full text-center bg-primary text-white font-semibold text-[16px] px-[26px] py-[14px] border-2 border-primary hover:bg-primary-hover transition-colors"
      >
        Get a Free Estimate
      </a>
    </div>
  </div>
</div>

<script>
  // ── Hamburger ──────────────────────────────────────────────
  const btn  = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-nav");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");

  function openMenu() {
    menu?.classList.remove("hidden");
    menu?.classList.add("flex");
    btn?.setAttribute("aria-expanded", "true");
    bar1?.classList.add("rotate-45", "translate-y-[8px]");
    bar2?.classList.add("opacity-0");
    bar3?.classList.add("-rotate-45", "-translate-y-[8px]");
  }

  function closeMenu() {
    menu?.classList.add("hidden");
    menu?.classList.remove("flex");
    btn?.setAttribute("aria-expanded", "false");
    bar1?.classList.remove("rotate-45", "translate-y-[8px]");
    bar2?.classList.remove("opacity-0");
    bar3?.classList.remove("-rotate-45", "-translate-y-[8px]");
  }

  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    expanded ? closeMenu() : openMenu();
  });

  // Close on direct link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // ── Mobile accordions ──────────────────────────────────────
  function initAccordions() {
    document.querySelectorAll(".mobile-accordion-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const panel = btn.nextElementSibling as HTMLElement | null;
        const icon  = btn.querySelector(".accordion-icon") as HTMLElement | null;
        const isOpen = btn.getAttribute("aria-expanded") === "true";

        if (isOpen) {
          panel?.classList.add("hidden");
          icon?.classList.remove("rotate-180");
          btn.setAttribute("aria-expanded", "false");
        } else {
          panel?.classList.remove("hidden");
          icon?.classList.add("rotate-180");
          btn.setAttribute("aria-expanded", "true");
        }
      });
    });
  }

  initAccordions();
  document.addEventListener("astro:page-load", initAccordions);
</script>
