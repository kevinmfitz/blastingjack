---
import { Image } from "astro:assets";
import logo from "../assets/images/logo-full.png";
---

<footer class="bg-dark text-white">
  <div class="max-w-[1400px] mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1 — Brand + Contact -->
      <div>
        <Image src={logo} alt="Blasting Jack" width={100} height={76} class="h-[76px] w-auto mb-4 brightness-0 invert" />
        <p class="text-white/70 text-[15px] leading-relaxed mb-6">
          Mobile sandblasting and surface preparation contractor serving Michigan — from tank and silo blasting to structural steel, equipment, and historic restoration.
        </p>
        <ul class="space-y-3 text-[14px]">
          <li>
            <a href="mailto:info@blastingjack.com" class="text-white/70 hover:text-white transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              info@blastingjack.com
            </a>
          </li>
          <li>
            <a href="tel:8106026809" class="text-white/70 hover:text-white transition-colors flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              810-602-6809
            </a>
          </li>
          <li>
            <span class="text-white/70 flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 shrink-0"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              14500 East Eleven, Warren MI, 48089
            </span>
          </li>
        </ul>
      </div>

      <!-- Col 2 — Services -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.12em] mb-5">Services</h3>
        <ul class="space-y-2 text-[14px]">
          {[
            { label: "Mobile Sandblasting", href: "/services/mobile-sandblasting/" },
            { label: "Abrasive Blasting", href: "/services/abrasive-blasting/" },
            { label: "Industrial Sandblasting", href: "/services/industrial-sandblasting/" },
            { label: "Vapor / Dustless Blasting", href: "/services/vapor-dustless-blasting/" },
            { label: "Dry Ice Blasting", href: "/services/dry-ice-blasting/" },
            { label: "Coating Removal", href: "/services/coating-removal/" },
            { label: "Rust Removal", href: "/services/rust-removal/" },
            { label: "Steel Surface Preparation", href: "/services/steel-surface-preparation/" },
            { label: "Equipment Blasting", href: "/services/equipment-blasting/" },
            { label: "Tank & Silo Blasting", href: "/services/tank-silo-blasting/" },
            { label: "Structural Steel Blasting", href: "/services/structural-steel-blasting/" },
            { label: "Surface Prep for Coatings", href: "/services/surface-preparation-for-coatings/" },
          ].map(item => (
            <li>
              <a href={item.href} class="text-white/65 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Industries + Areas Served -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.12em] mb-5">Industries</h3>
        <ul class="space-y-2 text-[14px] mb-8">
          {[
            { label: "Steel Fabricators", href: "/industries/steel-fabricators/" },
            { label: "Manufacturing Plants", href: "/industries/manufacturing-plants/" },
            { label: "Tanks & Silos", href: "/industries/tanks-silos/" },
            { label: "Parking Garages", href: "/industries/parking-garages/" },
            { label: "General Contractors", href: "/industries/general-contractors/" },
            { label: "Historic Restoration", href: "/industries/historic-restoration/" },
          ].map(item => (
            <li>
              <a href={item.href} class="text-white/65 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.12em] mb-5">Areas Served</h3>
        <ul class="space-y-2 text-[14px]">
          {[
            { label: "Macomb County", href: "/areas-served/macomb-county-mobile-sandblasting/" },
            { label: "Oakland County", href: "/areas-served/oakland-county-mobile-sandblasting/" },
            { label: "Wayne County", href: "/areas-served/wayne-county-mobile-sandblasting/" },
            { label: "Washtenaw County", href: "/areas-served/washtenaw-county-mobile-sandblasting/" },
            { label: "Genesee County", href: "/areas-served/genesee-county-mobile-sandblasting/" },
            { label: "Livingston County", href: "/areas-served/livingston-county-mobile-sandblasting/" },
            { label: "St. Clair County", href: "/areas-served/st-clair-county-mobile-sandblasting/" },
            { label: "Monroe County", href: "/areas-served/monroe-county-mobile-sandblasting/" },
            { label: "Lapeer County", href: "/areas-served/lapeer-county-mobile-sandblasting/" },
          ].map(item => (
            <li>
              <a href={item.href} class="text-white/65 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Quick links + CTA + Social -->
      <div>
        <h3 class="text-white font-semibold text-[13px] uppercase tracking-[0.12em] mb-5">Quick Links</h3>
        <ul class="space-y-2 text-[14px] mb-8">
          <li><a href="/gallery/" class="text-white/65 hover:text-white transition-colors">Gallery / Our Work</a></li>
          <li><a href="/blog/" class="text-white/65 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/#whyus" class="text-white/65 hover:text-white transition-colors">Why Blasting Jack</a></li>
          <li><a href="/#contact" class="text-white/65 hover:text-white transition-colors">Contact</a></li>
        </ul>

        <a
          href="/#contact"
          class="inline-block w-full text-center bg-primary text-white font-semibold text-[14px] px-5 py-3 border-2 border-primary hover:bg-primary-hover transition-colors mb-8"
        >
          Request a Free Estimate
        </a>

        <!-- Sister brand -->
        <div class="border-t border-white/10 pt-6 mb-6">
          <p class="text-white/40 text-[11px] uppercase tracking-[0.12em] mb-2">Sister Brand</p>
          <p class="text-white/60 text-[13px] leading-relaxed">
            Blasting Jack prepares the surface.<br />
            <a href="https://endurancepainting.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary-hover transition-colors font-medium">Endurance Painting</a> protects the asset.
          </p>
        </div>

        <!-- Social -->
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-[1400px] mx-auto px-6 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-white/40 text-[13px]">
      <span>&copy; COPYRIGHT 2025 | BLASTING JACK | ALL RIGHTS RESERVED</span>
      <span>
        Sister brand:
        <a href="https://endurancepainting.com" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors ml-1">Endurance Painting</a>
      </span>
    </div>
  </div>
</footer>
